{
  "name": "chau7-ios-relay",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "test": "node --test test/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}' 'test/**/*.{ts,js,json}'",
    "format:write": "prettier --write 'src/**/*.{ts,js,json}' 'test/**/*.{ts,js,json}'",
    "build": "WRANGLER_SEND_METRICS=false wrangler deploy --dry-run",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260521.1",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "wrangler": "4.93.1"
  }
}
