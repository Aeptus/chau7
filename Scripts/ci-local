#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/ci-lib.sh"

ROOT_DIR="$(ci_repo_root)"

ci_note "Running full local CI for Chau7 from $ROOT_DIR"

SWIFT_BIN="$(ci_swift_bin)"
ci_require_cmd swiftformat "Install SwiftFormat (for example: brew install swiftformat)."
ci_require_cmd swiftlint "Install SwiftLint (for example: brew install swiftlint)."
ci_require_cmd cargo "Install Rust via rustup."
ci_require_cmd go "Install Go 1.25+."
ci_require_cmd npm "Install Node.js and npm."

ci_run_in "Swift format check" "apps/chau7-macos" swiftformat Sources Tests --lint
ci_run_in "Swift lint" "apps/chau7-macos" swiftlint lint --strict --quiet
ci_run_in "Swift build" "apps/chau7-macos" "$SWIFT_BIN" build -Xswiftc -warnings-as-errors
ci_run_in "Swift test" "apps/chau7-macos" "$SWIFT_BIN" test -Xswiftc -warnings-as-errors

ci_run_in "Rust format check" "apps/chau7-macos/rust" cargo fmt --all --check
ci_run_in "Rust clippy" "apps/chau7-macos/rust" cargo clippy --workspace --all-targets --all-features -- -D warnings
ci_run_in "Rust test" "apps/chau7-macos/rust" cargo test --workspace --all-features

ci_gofmt_check_dir "apps/chau7-macos/chau7-proxy" "Go format check (chau7-proxy)"
ci_go_vet_dir "apps/chau7-macos/chau7-proxy" "Go vet (chau7-proxy)"
ci_go_test_dir "apps/chau7-macos/chau7-proxy" "Go test (chau7-proxy)"

ci_gofmt_check_dir "services/chau7-remote" "Go format check (chau7-remote)"
ci_go_vet_dir "services/chau7-remote" "Go vet (chau7-remote)"
ci_go_test_dir "services/chau7-remote" "Go test (chau7-remote)"

ci_relay_ensure_deps
ci_run_in "Relay test" "services/chau7-relay" npm test
ci_run_in "Relay build" "services/chau7-relay" npm run build

ci_success "Full local CI passed."
