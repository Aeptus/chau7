#!/usr/bin/env bash
# Scoped TS check for services/chau7-relay.
# Runs tsc --noEmit + prettier --check against the relay worker source.
# Used by pre-commit (glob-scoped by lefthook) and pre-push (full).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/ci-lib.sh"

ROOT_DIR="$(ci_repo_root)"
RELAY_DIR="$ROOT_DIR/services/chau7-relay"

if [[ ! -d "$RELAY_DIR" ]]; then
  ci_fail "Relay directory not found: $RELAY_DIR"
fi

ci_require_cmd npx "Install Node.js (and npm)."

# Ensure tsc + prettier are available. Prefer locally installed versions so
# the check is reproducible, fall back to user PATH otherwise.
ci_run_in "Relay: tsc --noEmit" "services/chau7-relay" \
  npx --no-install tsc --noEmit -p tsconfig.json \
  || ci_run_in "Relay: tsc --noEmit (PATH)" "services/chau7-relay" \
       tsc --noEmit -p tsconfig.json

ci_run_in "Relay: prettier --check" "services/chau7-relay" \
  npx --no-install prettier --check 'src/**/*.{ts,js,json}' 'test/**/*.{ts,js,json}' \
  || ci_run_in "Relay: prettier --check (PATH)" "services/chau7-relay" \
       prettier --check 'src/**/*.{ts,js,json}' 'test/**/*.{ts,js,json}'
