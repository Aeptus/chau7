#!/usr/bin/env python3
import argparse
import json
import os
import socket
import subprocess
import sys
from pathlib import Path
from typing import Any


DEFAULT_GATE = "advisory"
DEFAULT_TIMEOUT_MS = 45_000
DEFAULT_BACKEND = "codex"
DEFAULT_MODEL = "gpt-5.3-codex"
SOCKET_PATH = Path.home() / "Library/Application Support/Chau7/scripting.sock"
DEFAULT_CONFIG_NAME = ".chau7/pre-commit-review.conf"
CHAU7_BUNDLE_ID = "com.aeptus.Chau7"
SCRIPTING_FLAG_KEY = "feature.scriptingAPI"

REVIEWABLE_EXTENSIONS = {
    ".c", ".cc", ".cpp", ".cs", ".go", ".h", ".hpp", ".java", ".js", ".json",
    ".jsx", ".kt", ".m", ".mm", ".php", ".py", ".rb", ".rs", ".sh", ".sql",
    ".swift", ".toml", ".ts", ".tsx", ".yaml", ".yml",
}
REVIEWABLE_FILENAMES = {
    "Package.swift", "Makefile", "Dockerfile", ".swiftformat", ".swiftlint.yml",
}


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run a delegated Chau7 pre-commit code review over staged changes.")
    parser.add_argument("--gate")
    parser.add_argument(
        "--timeout-ms",
        type=int,
    )
    parser.add_argument("--model")
    parser.add_argument("--backend")
    parser.add_argument(
        "--enabled",
        default=None,
        help="Set to 0/false/off to disable the review without removing the hook.",
    )
    parser.add_argument("--config")
    return parser.parse_args()


def repo_root() -> Path:
    output = subprocess.check_output(
        ["git", "rev-parse", "--show-toplevel"],
        text=True,
        stderr=subprocess.DEVNULL,
    )
    return Path(output.strip())


def default_config(root: Path) -> dict[str, str]:
    return {
        "enabled": "1",
        "gate": DEFAULT_GATE,
        "timeout_ms": str(DEFAULT_TIMEOUT_MS),
        "model": DEFAULT_MODEL,
        "backend": DEFAULT_BACKEND,
        "config_path": str(root / DEFAULT_CONFIG_NAME),
    }


def strip_quotes(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def load_config_file(path: Path) -> dict[str, str]:
    result: dict[str, str] = {}
    if not path.exists():
        return result

    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        normalized_key = key.strip().lower()
        if normalized_key not in {"enabled", "gate", "timeout_ms", "model", "backend"}:
            continue
        result[normalized_key] = strip_quotes(value)
    return result


def resolve_config(root: Path, args: argparse.Namespace) -> dict[str, str]:
    config = default_config(root)

    config_path = args.config or os.environ.get("CHAU7_PRE_COMMIT_REVIEW_CONFIG") or config["config_path"]
    config["config_path"] = config_path
    config.update(load_config_file(Path(config_path)))

    env_map = {
        "enabled": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_ENABLED"),
        "gate": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_GATE"),
        "timeout_ms": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_TIMEOUT_MS"),
        "model": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_MODEL"),
        "backend": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_BACKEND"),
    }
    for key, value in env_map.items():
        if value is not None:
            config[key] = value

    if args.enabled is not None:
        config["enabled"] = args.enabled
    if args.gate is not None:
        config["gate"] = args.gate
    if args.timeout_ms is not None:
        config["timeout_ms"] = str(args.timeout_ms)
    if args.model is not None:
        config["model"] = args.model
    if args.backend is not None:
        config["backend"] = args.backend

    return config


def staged_files(root: Path) -> list[str]:
    output = subprocess.check_output(
        ["git", "-C", str(root), "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
        text=True,
    )
    return [line.strip() for line in output.splitlines() if line.strip()]


def is_reviewable(path: str) -> bool:
    pure = Path(path)
    if pure.name in REVIEWABLE_FILENAMES:
        return True
    if pure.suffix.lower() in REVIEWABLE_EXTENSIONS:
        return True
    return False


def staged_diff(root: Path, files: list[str]) -> str:
    if not files:
        return ""
    command = ["git", "-C", str(root), "diff", "--cached", "--no-ext-diff", "--unified=3", "--"]
    command.extend(files)
    output = subprocess.check_output(command, text=True, errors="replace")
    return output.strip()


def socket_call(method: str, params: dict[str, Any]) -> dict[str, Any]:
    if not SOCKET_PATH.exists():
        raise FileNotFoundError(f"scripting socket not found at {SOCKET_PATH}")

    request = {
        "id": f"precommit-{os.getpid()}-{method}",
        "method": method,
        "params": params,
    }

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.connect(str(SOCKET_PATH))
        payload = json.dumps(request, sort_keys=True).encode("utf-8") + b"\n"
        client.sendall(payload)

        response = bytearray()
        while True:
            chunk = client.recv(8192)
            if not chunk:
                break
            response.extend(chunk)
            if b"\n" in chunk:
                break

    line = response.split(b"\n", 1)[0].decode("utf-8")
    return json.loads(line)


def print_skip(reason: str) -> None:
    print(f"pre-commit review: {reason}", file=sys.stderr)


def chau7_is_running() -> bool:
    result = subprocess.run(
        ["pgrep", "-x", "Chau7"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return result.returncode == 0


def read_scripting_flag() -> bool | None:
    result = subprocess.run(
        ["defaults", "read", CHAU7_BUNDLE_ID, SCRIPTING_FLAG_KEY],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return None

    normalized = result.stdout.strip().lower()
    if normalized in {"1", "true", "yes"}:
        return True
    if normalized in {"0", "false", "no"}:
        return False
    return None


def describe_scripting_unavailable(exc: Exception) -> str:
    if not chau7_is_running():
        return f"unable to reach Chau7 scripting API ({exc}); Chau7 is not running; skipping"

    flag = read_scripting_flag()
    if flag is False:
        return (
            f"unable to reach Chau7 scripting API ({exc}); Chau7 is running but {SCRIPTING_FLAG_KEY} is disabled; skipping"
        )
    if flag is True:
        return (
            f"unable to reach Chau7 scripting API ({exc}); Chau7 is running and scripting is enabled, "
            "but the socket is unavailable; skipping"
        )
    return (
        f"unable to reach Chau7 scripting API ({exc}); Chau7 is running, but scripting may still be starting "
        "or failed to start; skipping"
    )


def format_finding(finding: dict[str, Any]) -> str:
    severity = str(finding.get("severity", "unknown")).lower()
    file = str(finding.get("file", "(unknown)"))
    line = finding.get("line")
    location = f"{file}:{line}" if isinstance(line, int) else file
    message = str(finding.get("message", "")).strip()
    recommendation = str(finding.get("recommendation", "")).strip()
    rendered = f"[{severity}] {location} {message}".rstrip()
    if recommendation:
        rendered += f"\n  recommendation: {recommendation}"
    return rendered


def has_blocking_findings(gate: str, findings: list[dict[str, Any]]) -> bool:
    normalized = gate.lower()
    if normalized == "off":
        return False
    if normalized == "advisory":
        return False
    if normalized in {"any", "fail-on-any"}:
        return len(findings) > 0
    if normalized in {"high", "fail-on-high"}:
        return any(str(item.get("severity", "")).lower() == "high" for item in findings)
    return False


def main() -> int:
    args = parse_args()

    try:
        root = repo_root()
    except subprocess.CalledProcessError:
        print_skip("not inside a git repository; skipping")
        return 0

    config = resolve_config(root, args)
    if str(config["enabled"]).strip().lower() in {"0", "false", "off", "no"}:
        return 0

    try:
        timeout_ms = int(config["timeout_ms"])
    except ValueError:
        timeout_ms = DEFAULT_TIMEOUT_MS
    gate = config["gate"]
    backend = config["backend"] or DEFAULT_BACKEND
    model = config["model"] or None

    reviewable_files = [path for path in staged_files(root) if is_reviewable(path)]
    if not reviewable_files:
        return 0

    diff = staged_diff(root, reviewable_files)
    if not diff:
        return 0

    try:
        start_response = socket_call(
            "start_review",
            {
                "directory": str(root),
                "backend": backend,
                "mode": "staged_diff",
                "staged_files": reviewable_files,
                "staged_diff": diff,
                "model": model,
            },
        )
    except (FileNotFoundError, OSError, json.JSONDecodeError) as exc:
        print_skip(describe_scripting_unavailable(exc))
        return 0

    if "error" in start_response:
        print_skip(f"unable to start review ({start_response['error']}); skipping")
        return 0

    session_id = start_response.get("session_id")
    if not isinstance(session_id, str) or not session_id:
        print_skip("review session did not return a session_id; skipping")
        return 0

    wait_response = socket_call("wait_review", {"session_id": session_id, "timeout_ms": timeout_ms})
    if wait_response.get("timed_out") is True:
        print_skip(f"review timed out after {timeout_ms}ms; skipping")
        return 0

    result_response = socket_call("get_review_result", {"session_id": session_id})
    if "error" in result_response:
        print_skip(f"review did not produce a result ({result_response['error']}); skipping")
        return 0

    status = str(result_response.get("status", "missing")).lower()
    if status != "available":
        print_skip(f"structured review result unavailable (status={status}); skipping")
        return 0

    value = result_response.get("value")
    if not isinstance(value, dict):
        print_skip("review result payload was malformed; skipping")
        return 0

    findings = value.get("findings")
    if not isinstance(findings, list):
        print_skip("review findings payload was malformed; skipping")
        return 0

    findings = [item for item in findings if isinstance(item, dict)]
    if not findings:
        return 0

    summary = str(value.get("summary", "Pre-commit review reported findings.")).strip()
    confidence = str(value.get("confidence", "unknown")).strip()
    recommendations = value.get("recommendations")
    print(f"pre-commit review: {summary} (confidence: {confidence})", file=sys.stderr)
    for finding in findings:
        print(format_finding(finding), file=sys.stderr)
    if isinstance(recommendations, list):
        rendered = [str(item).strip() for item in recommendations if str(item).strip()]
        if rendered:
            print("recommendations:", file=sys.stderr)
            for item in rendered:
                print(f"- {item}", file=sys.stderr)

    if has_blocking_findings(gate, findings):
        print("pre-commit review blocked the commit.", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
