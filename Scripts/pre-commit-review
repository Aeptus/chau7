#!/usr/bin/env python3
import argparse
import json
import os
import re
import socket
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

DEFAULT_GATE = "advisory"
DEFAULT_TIMEOUT_MS = 45_000
DEFAULT_STARTUP_TIMEOUT_MS = 20_000
DEFAULT_BACKEND = "codex"
DEFAULT_MODEL = "gpt-5.3-codex"
DEFAULT_SOCKET_TIMEOUT_SECONDS = 15.0
DEFAULT_STATUS_POLL_SECONDS = 0.2
DEFAULT_OUTPUT_POLL_SECONDS = 0.5
PROMPT_VALIDATION_TIMEOUT_MS = 5_000
SUBMIT_START_TIMEOUT_MS = 5_000
DEFAULT_OUTPUT_LINES = 4_000
PROMPT_VALIDATION_LINES = 240
PROMPT_SENTINEL = "REVIEW TASK: PRE-COMMIT CODE REVIEW"
SOCKET_PATH = Path.home() / "Library/Application Support/Chau7/scripting.sock"
DEFAULT_CONFIG_NAME = ".chau7/pre-commit-review.conf"
CHAU7_BUNDLE_ID = "com.aeptus.Chau7"
SCRIPTING_FLAG_KEY = "feature.scriptingAPI"

REVIEWABLE_EXTENSIONS = {
    ".c",
    ".cc",
    ".cpp",
    ".cs",
    ".go",
    ".h",
    ".hpp",
    ".java",
    ".js",
    ".json",
    ".jsx",
    ".kt",
    ".m",
    ".mm",
    ".php",
    ".py",
    ".rb",
    ".rs",
    ".sh",
    ".sql",
    ".swift",
    ".toml",
    ".ts",
    ".tsx",
    ".yaml",
    ".yml",
}
REVIEWABLE_FILENAMES = {
    "Package.swift",
    "Makefile",
    "Dockerfile",
    ".swiftformat",
    ".swiftlint.yml",
}


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run a delegated Chau7 pre-commit code review over staged changes.")
    parser.add_argument("--gate")
    parser.add_argument(
        "--timeout-ms",
        type=int,
    )
    parser.add_argument(
        "--startup-timeout-ms",
        type=int,
    )
    parser.add_argument("--model")
    parser.add_argument("--backend")
    parser.add_argument(
        "--enabled",
        default=None,
        help="Set to 0/false/off to disable the review without removing the hook.",
    )
    parser.add_argument("--config")
    return parser.parse_args()


def repo_root() -> Path:
    output = subprocess.check_output(
        ["git", "rev-parse", "--show-toplevel"],
        text=True,
        stderr=subprocess.DEVNULL,
    )
    return Path(output.strip())


def default_config(root: Path) -> dict[str, str]:
    return {
        "enabled": "1",
        "gate": DEFAULT_GATE,
        "timeout_ms": str(DEFAULT_TIMEOUT_MS),
        "startup_timeout_ms": str(DEFAULT_STARTUP_TIMEOUT_MS),
        "model": DEFAULT_MODEL,
        "backend": DEFAULT_BACKEND,
        "config_path": str(root / DEFAULT_CONFIG_NAME),
    }


def strip_quotes(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def load_config_file(path: Path) -> dict[str, str]:
    result: dict[str, str] = {}
    if not path.exists():
        return result

    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        normalized_key = key.strip().lower()
        if normalized_key not in {"enabled", "gate", "timeout_ms", "startup_timeout_ms", "model", "backend"}:
            continue
        result[normalized_key] = strip_quotes(value)
    return result


def resolve_config(root: Path, args: argparse.Namespace) -> dict[str, str]:
    config = default_config(root)

    config_path = args.config or os.environ.get("CHAU7_PRE_COMMIT_REVIEW_CONFIG") or config["config_path"]
    config["config_path"] = config_path
    config.update(load_config_file(Path(config_path)))

    env_map = {
        "enabled": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_ENABLED"),
        "gate": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_GATE"),
        "timeout_ms": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_TIMEOUT_MS"),
        "startup_timeout_ms": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_STARTUP_TIMEOUT_MS"),
        "model": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_MODEL"),
        "backend": os.environ.get("CHAU7_PRE_COMMIT_REVIEW_BACKEND"),
    }
    for key, value in env_map.items():
        if value is not None:
            config[key] = value

    if args.enabled is not None:
        config["enabled"] = args.enabled
    if args.gate is not None:
        config["gate"] = args.gate
    if args.timeout_ms is not None:
        config["timeout_ms"] = str(args.timeout_ms)
    if args.startup_timeout_ms is not None:
        config["startup_timeout_ms"] = str(args.startup_timeout_ms)
    if args.model is not None:
        config["model"] = args.model
    if args.backend is not None:
        config["backend"] = args.backend

    return config


def staged_files(root: Path) -> list[str]:
    output = subprocess.check_output(
        ["git", "-C", str(root), "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
        text=True,
    )
    return [line.strip() for line in output.splitlines() if line.strip()]


def is_reviewable(path: str) -> bool:
    pure = Path(path)
    if pure.name in REVIEWABLE_FILENAMES:
        return True
    return pure.suffix.lower() in REVIEWABLE_EXTENSIONS


def staged_diff(root: Path, files: list[str]) -> str:
    if not files:
        return ""
    command = ["git", "-C", str(root), "diff", "--cached", "--no-ext-diff", "--unified=3", "--"]
    command.extend(files)
    output = subprocess.check_output(command, text=True, errors="replace")
    return output.strip()


def socket_timeout_seconds(method: str, params: dict[str, Any]) -> float:
    if method in {"stop_session", "close_tab"}:
        return 2.0
    if method == "get_output":
        wait_for_stable_ms = params.get("wait_for_stable_ms")
        if isinstance(wait_for_stable_ms, int) and wait_for_stable_ms > 0:
            return max(DEFAULT_SOCKET_TIMEOUT_SECONDS, (wait_for_stable_ms / 1000.0) + 2.0)
    return DEFAULT_SOCKET_TIMEOUT_SECONDS


def socket_call(method: str, params: dict[str, Any]) -> dict[str, Any]:
    if not SOCKET_PATH.exists():
        raise FileNotFoundError(f"scripting socket not found at {SOCKET_PATH}")

    request = {
        "id": f"precommit-{os.getpid()}-{method}",
        "method": method,
        "params": params,
    }

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(socket_timeout_seconds(method, params))
        client.connect(str(SOCKET_PATH))
        payload = json.dumps(request, sort_keys=True).encode("utf-8") + b"\n"
        client.sendall(payload)

        response = bytearray()
        while True:
            chunk = client.recv(8192)
            if not chunk:
                break
            response.extend(chunk)
            if b"\n" in chunk:
                break

    line = response.split(b"\n", 1)[0].decode("utf-8")
    return json.loads(line)


_LOUD_SKIP_CODES = {
    "app_down",
    "scripting_disabled",
    "socket_timeout",
    "socket_connection_refused",
    "socket_permission_denied",
}


def _loud_skip_enabled() -> bool:
    value = os.environ.get("CHAU7_PRE_COMMIT_REVIEW_QUIET", "")
    return value.strip().lower() not in {"1", "true", "yes", "on"}


def print_skip(reason: str, code: str | None = None) -> None:
    if code in _LOUD_SKIP_CODES and _loud_skip_enabled():
        banner = "⚠ pre-commit review SKIPPED — Chau7 app not reachable"
        bar = "=" * max(len(banner), len(reason))
        print(bar, file=sys.stderr)
        print(banner, file=sys.stderr)
        print(reason, file=sys.stderr)
        print(
            "  (silence with CHAU7_PRE_COMMIT_REVIEW_QUIET=1; disable with CHAU7_PRE_COMMIT_REVIEW_ENABLED=0)",
            file=sys.stderr,
        )
        print(bar, file=sys.stderr)
        return
    print(f"pre-commit review: {reason}", file=sys.stderr)


def chau7_is_running() -> bool:
    result = subprocess.run(
        ["ps", "-axo", "command="],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return False

    candidates = [
        "/Applications/Chau7.app/Contents/MacOS/Chau7",
        "/build/Chau7.app/Contents/MacOS/Chau7",
    ]
    return any(candidate in result.stdout for candidate in candidates)


def read_scripting_flag() -> bool | None:
    result = subprocess.run(
        ["defaults", "read", CHAU7_BUNDLE_ID, SCRIPTING_FLAG_KEY],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return None

    normalized = result.stdout.strip().lower()
    if normalized in {"1", "true", "yes"}:
        return True
    if normalized in {"0", "false", "no"}:
        return False
    return None


def describe_scripting_unavailable(exc: Exception) -> tuple[str, str]:
    if isinstance(exc, ConnectionRefusedError):
        return (
            "socket_connection_refused",
            f"unable to reach Chau7 scripting API ({exc}); the socket exists but no server is accepting "
            "connections; Chau7 may have left behind a stale socket or the scripting server failed to start; skipping",
        )
    if isinstance(exc, TimeoutError):
        return (
            "socket_timeout",
            f"unable to reach Chau7 scripting API ({exc}); the scripting socket did not respond before the client timeout; "
            "skipping",
        )
    if isinstance(exc, PermissionError):
        return (
            "socket_permission_denied",
            f"unable to reach Chau7 scripting API ({exc}); the socket exists but this process was denied access; "
            "check local macOS permissions or sandboxing; skipping",
        )
    if not chau7_is_running():
        return ("app_down", f"unable to reach Chau7 scripting API ({exc}); Chau7 is not running; skipping")

    flag = read_scripting_flag()
    if flag is False:
        return (
            "scripting_disabled",
            f"unable to reach Chau7 scripting API ({exc}); Chau7 is running but {SCRIPTING_FLAG_KEY} is disabled; skipping",
        )
    if flag is True:
        return (
            "socket_unavailable",
            f"unable to reach Chau7 scripting API ({exc}); Chau7 is running and scripting is enabled, "
            "but the socket is unavailable; skipping",
        )
    return (
        "socket_unavailable",
        f"unable to reach Chau7 scripting API ({exc}); Chau7 is running, but scripting may still be starting "
        "or failed to start; skipping",
    )


def format_finding(finding: dict[str, Any]) -> str:
    severity = str(finding.get("severity", "unknown")).lower()
    file = str(finding.get("file", "(unknown)"))
    line = finding.get("line")
    location = f"{file}:{line}" if isinstance(line, int) else file
    message = str(finding.get("message", "")).strip()
    recommendation = str(finding.get("recommendation", "")).strip()
    rendered = f"[{severity}] {location} {message}".rstrip()
    if recommendation:
        rendered += f"\n  recommendation: {recommendation}"
    return rendered


def has_blocking_findings(gate: str, findings: list[dict[str, Any]]) -> bool:
    normalized = gate.lower()
    if normalized == "off":
        return False
    if normalized == "advisory":
        return False
    if normalized in {"any", "fail-on-any"}:
        return len(findings) > 0
    if normalized in {"high", "fail-on-high"}:
        return any(str(item.get("severity", "")).lower() == "high" for item in findings)
    return False


def review_grace_timeout_ms(timeout_ms: int) -> int:
    return max(5_000, min(15_000, timeout_ms // 3))

def create_review_prompt(staged_files: list[str], diff: str) -> str:
    lines = [
        PROMPT_SENTINEL,
        "Review the staged changes that are about to be committed.",
        "Only evaluate the staged diff below. Do not speculate about unstaged changes.",
        "Work read-only. Do not edit files.",
        "Focus on correctness, regressions, security, and missing tests.",
        "Return concise prose findings first, then end with exactly one fenced JSON block and nothing after it.",
        "Use this exact JSON shape:",
        "```json",
        "{",
        '  "summary": "string",',
        '  "findings": [',
        "    {",
        '      "severity": "low|medium|high",',
        '      "file": "path",',
        '      "line": 123,',
        '      "message": "string",',
        '      "recommendation": "string"',
        "    }",
        "  ],",
        '  "recommendations": ["string"],',
        '  "confidence": "low|medium|high"',
        "}",
        "```",
    ]
    if staged_files:
        lines.append("Staged files:")
        lines.extend(f"- {path}" for path in staged_files)
    lines.append("Staged diff:")
    lines.append("```diff")
    lines.append(diff)
    lines.append("```")
    return "\n".join(lines)


def create_tab(root: Path) -> dict[str, Any]:
    return socket_call("create_tab", {"directory": str(root)})


def get_tab(tab_id: str) -> dict[str, Any]:
    return socket_call("get_tab", {"id": tab_id})


def run_command(tab_id: str, command: str) -> dict[str, Any]:
    return socket_call("run_command", {"tab_id": tab_id, "command": command})


def send_input(tab_id: str, input_text: str) -> dict[str, Any]:
    return socket_call("send_input", {"tab_id": tab_id, "input": input_text})


def submit_prompt(tab_id: str) -> dict[str, Any]:
    return socket_call("submit_prompt", {"tab_id": tab_id})


def get_output(tab_id: str, lines: int, source: str, wait_for_stable_ms: int | None = None) -> dict[str, Any]:
    params: dict[str, Any] = {
        "tab_id": tab_id,
        "lines": lines,
        "source": source,
    }
    if wait_for_stable_ms is not None:
        params["wait_for_stable_ms"] = wait_for_stable_ms
    return socket_call("get_output", params)


def close_tab(tab_id: str) -> None:
    try:
        response = socket_call("close_tab", {"id": tab_id})
    except (FileNotFoundError, OSError, TimeoutError, json.JSONDecodeError) as exc:
        print_skip(f"unable to clean up review tab {tab_id} ({exc})")
        return
    if "error" in response:
        print_skip(f"unable to clean up review tab {tab_id} ({response['error']})")


def normalized_status(response: dict[str, Any]) -> str:
    return str(response.get("status", "")).strip().lower()


def normalized_active_app(response: dict[str, Any]) -> str:
    return str(response.get("active_app", "")).strip().lower()


def is_prompt_ready(response: dict[str, Any]) -> bool:
    return bool(response.get("is_at_prompt")) and normalized_status(response) == "idle"


def wait_for_tab_state(
    tab_id: str,
    timeout_ms: int,
    predicate,
) -> tuple[dict[str, Any] | None, str | None]:
    deadline = time.monotonic() + max(timeout_ms, 1) / 1000.0
    last_response: dict[str, Any] | None = None
    while time.monotonic() < deadline:
        response = get_tab(tab_id)
        if "error" in response:
            return None, str(response["error"])
        last_response = response
        if predicate(response):
            return response, None
        time.sleep(DEFAULT_STATUS_POLL_SECONDS)
    return last_response, "timed_out"


def extract_review_json(text: str) -> dict[str, Any] | None:
    fenced_blocks = re.findall(r"```json\s*(\{.*?\})\s*```", text, re.DOTALL | re.IGNORECASE)
    candidates = fenced_blocks[::-1]

    if not candidates:
        generic_blocks = re.findall(r"```\s*(\{.*?\})\s*```", text, re.DOTALL)
        candidates.extend(reversed(generic_blocks))

    for candidate in candidates:
        try:
            payload = json.loads(candidate)
        except json.JSONDecodeError:
            continue
        if is_valid_review_payload(payload):
            return payload
    return None


def is_valid_review_payload(payload: Any) -> bool:
    if not isinstance(payload, dict):
        return False
    if not isinstance(payload.get("summary"), str):
        return False
    if not isinstance(payload.get("findings"), list):
        return False
    if not isinstance(payload.get("recommendations"), list):
        return False
    confidence = payload.get("confidence")
    if not isinstance(confidence, str) or confidence not in {"low", "medium", "high"}:
        return False
    for item in payload["findings"]:
        if not isinstance(item, dict):
            return False
        if not isinstance(item.get("severity"), str):
            return False
        if not isinstance(item.get("file"), str):
            return False
        if not isinstance(item.get("message"), str):
            return False
    return True


def extract_output_text(tab_id: str, lines: int = DEFAULT_OUTPUT_LINES) -> str:
    response = get_output(tab_id, lines, "pty_log")
    if "error" not in response:
        output = response.get("output")
        if isinstance(output, str) and output.strip():
            return output

    fallback = get_output(tab_id, min(lines, 800), "buffer", wait_for_stable_ms=500)
    if "error" in fallback:
        return ""
    output = fallback.get("output")
    return output if isinstance(output, str) else ""


def validate_prompt_visible(tab_id: str, timeout_ms: int) -> bool:
    deadline = time.monotonic() + max(timeout_ms, 1) / 1000.0
    while time.monotonic() < deadline:
        response = get_output(tab_id, PROMPT_VALIDATION_LINES, "buffer", wait_for_stable_ms=300)
        if "error" not in response:
            output = response.get("output")
            if isinstance(output, str) and PROMPT_SENTINEL in output:
                return True
        time.sleep(DEFAULT_STATUS_POLL_SECONDS)
    return False


def wait_for_submission_start(tab_id: str, baseline_output: str, timeout_ms: int) -> bool:
    deadline = time.monotonic() + max(timeout_ms, 1) / 1000.0
    while time.monotonic() < deadline:
        status = get_tab(tab_id)
        if "error" not in status:
            if not is_prompt_ready(status):
                return True
        current_output = extract_output_text(tab_id)
        if current_output != baseline_output:
            return True
        time.sleep(DEFAULT_OUTPUT_POLL_SECONDS)
    return False


def submit_prompt_with_fallback(tab_id: str, baseline_output: str) -> bool:
    response = submit_prompt(tab_id)
    if "error" in response:
        return False
    if wait_for_submission_start(tab_id, baseline_output, SUBMIT_START_TIMEOUT_MS):
        return True

    newline_response = send_input(tab_id, "\n")
    if "error" in newline_response:
        return False
    return wait_for_submission_start(tab_id, baseline_output, SUBMIT_START_TIMEOUT_MS)


def wait_for_review_completion(tab_id: str, timeout_ms: int) -> tuple[dict[str, Any] | None, str]:
    deadline = time.monotonic() + max(timeout_ms, 1) / 1000.0
    last_output = extract_output_text(tab_id)
    stable_polls = 0

    while time.monotonic() < deadline:
        status = get_tab(tab_id)
        if "error" in status:
            return None, str(status["error"])

        current_output = extract_output_text(tab_id)
        if current_output == last_output:
            stable_polls += 1
        else:
            stable_polls = 0
            last_output = current_output

        payload = extract_review_json(current_output)
        if payload is not None and is_prompt_ready(status) and stable_polls >= 2:
            return payload, current_output

        time.sleep(DEFAULT_OUTPUT_POLL_SECONDS)

    return None, last_output


def main() -> int:
    args = parse_args()

    try:
        root = repo_root()
    except subprocess.CalledProcessError:
        print_skip("not inside a git repository; skipping")
        return 0

    config = resolve_config(root, args)
    if str(config["enabled"]).strip().lower() in {"0", "false", "off", "no"}:
        return 0

    try:
        timeout_ms = int(config["timeout_ms"])
    except ValueError:
        timeout_ms = DEFAULT_TIMEOUT_MS
    try:
        startup_timeout_ms = int(config.get("startup_timeout_ms", DEFAULT_STARTUP_TIMEOUT_MS))
    except ValueError:
        startup_timeout_ms = DEFAULT_STARTUP_TIMEOUT_MS
    gate = config["gate"]
    backend = config["backend"] or DEFAULT_BACKEND
    model = config["model"] or None

    reviewable_files = [path for path in staged_files(root) if is_reviewable(path)]
    if not reviewable_files:
        return 0

    diff = staged_diff(root, reviewable_files)
    if not diff:
        return 0

    tab_id: str | None = None
    exit_code = 0
    prompt = create_review_prompt(reviewable_files, diff)

    try:
        try:
            create_response = create_tab(root)
        except (FileNotFoundError, OSError, TimeoutError, json.JSONDecodeError) as exc:
            code, reason = describe_scripting_unavailable(exc)
            print_skip(reason, code)
            return 0

        if "error" in create_response:
            print_skip(f"unable to create review tab ({create_response['error']}); skipping")
            return 0

        tab_id = create_response.get("tab_id")
        if not isinstance(tab_id, str) or not tab_id:
            print_skip("review tab creation did not return a tab_id; skipping")
            return 0

        try:
            _, shell_error = wait_for_tab_state(
                tab_id,
                startup_timeout_ms,
                lambda response: bool(response.get("shell_loading")) is False and bool(response.get("is_at_prompt")),
            )
        except (FileNotFoundError, OSError, TimeoutError, json.JSONDecodeError) as exc:
            code, reason = describe_scripting_unavailable(exc)
            print_skip(reason, code)
            return 0
        if shell_error:
            print_skip(f"review tab did not reach shell prompt within {startup_timeout_ms}ms; skipping")
            return 0

        launch_model = model or DEFAULT_MODEL
        launch_command = f"codex --model {launch_model}"

        try:
            launch_response = run_command(tab_id, launch_command)
        except (FileNotFoundError, OSError, TimeoutError, json.JSONDecodeError) as exc:
            code, reason = describe_scripting_unavailable(exc)
            print_skip(reason, code)
            return 0
        if "error" in launch_response:
            print_skip(f"unable to launch Codex ({launch_response['error']}); skipping")
            return 0

        try:
            _, codex_error = wait_for_tab_state(
                tab_id,
                startup_timeout_ms,
                lambda response: normalized_active_app(response) == "codex" and is_prompt_ready(response),
            )
        except (FileNotFoundError, OSError, TimeoutError, json.JSONDecodeError) as exc:
            code, reason = describe_scripting_unavailable(exc)
            print_skip(reason, code)
            return 0
        if codex_error:
            print_skip(f"Codex did not become interactive within {startup_timeout_ms}ms; skipping")
            return 0

        try:
            send_response = send_input(tab_id, prompt)
        except (FileNotFoundError, OSError, TimeoutError, json.JSONDecodeError) as exc:
            code, reason = describe_scripting_unavailable(exc)
            print_skip(reason, code)
            return 0
        if "error" in send_response:
            print_skip(f"unable to send review input ({send_response['error']}); skipping")
            return 0

        try:
            if not validate_prompt_visible(tab_id, PROMPT_VALIDATION_TIMEOUT_MS):
                print_skip("review prompt did not appear in the Codex composer before submission; skipping")
                return 0

            baseline_output = extract_output_text(tab_id)
            if not submit_prompt_with_fallback(tab_id, baseline_output):
                print_skip("unable to submit review prompt to Codex; skipping")
                return 0

            result_payload, _ = wait_for_review_completion(tab_id, timeout_ms + review_grace_timeout_ms(timeout_ms))
        except (FileNotFoundError, OSError, TimeoutError, json.JSONDecodeError) as exc:
            code, reason = describe_scripting_unavailable(exc)
            print_skip(reason, code)
            return 0
        if result_payload is None:
            print_skip(f"review timed out after {timeout_ms}ms without a complete structured response; skipping")
            return 0

        findings = [item for item in result_payload.get("findings", []) if isinstance(item, dict)]
        if not findings:
            return 0

        summary = str(result_payload.get("summary", "Pre-commit review reported findings.")).strip()
        confidence = str(result_payload.get("confidence", "unknown")).strip()
        recommendations = result_payload.get("recommendations")
        print(f"pre-commit review: {summary} (confidence: {confidence})", file=sys.stderr)
        for finding in findings:
            print(format_finding(finding), file=sys.stderr)
        if isinstance(recommendations, list):
            rendered = [str(item).strip() for item in recommendations if str(item).strip()]
            if rendered:
                print("recommendations:", file=sys.stderr)
                for item in rendered:
                    print(f"- {item}", file=sys.stderr)

        if has_blocking_findings(gate, findings):
            print("pre-commit review blocked the commit.", file=sys.stderr)
            exit_code = 1
        return exit_code
    finally:
        # Temporary debugging: leave the review tab open so the live app state can be inspected.
        # if tab_id:
        #     close_tab(tab_id)
        pass


if __name__ == "__main__":
    raise SystemExit(main())
