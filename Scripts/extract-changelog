#!/usr/bin/env bash
#
# Extract release notes for a given version from CHANGELOG.md.
#
# Usage: extract-changelog <version>
#   version: semver without the "v" prefix (e.g. "0.5.0")
#
# Prints the markdown content between the version header and the next
# version header (or EOF). Exits 0 with empty output if the version
# is not found, so the release workflow can fall back gracefully.

set -euo pipefail

VERSION="${1:-}"
if [ -z "$VERSION" ]; then
  echo "Usage: extract-changelog <version>" >&2
  exit 1
fi

CHANGELOG="$(git rev-parse --show-toplevel)/apps/chau7-macos/docs/CHANGELOG.md"

if [ ! -f "$CHANGELOG" ]; then
  echo "CHANGELOG not found at $CHANGELOG" >&2
  exit 0
fi

# Match "## [VERSION]" exactly, print until the next "## [" header.
awk -v ver="$VERSION" '
  /^## \[/ {
    if (found) exit
    if ($0 ~ "^## \\[" ver "\\]") { found=1; next }
  }
  found { print }
' "$CHANGELOG"
