#!/usr/bin/env bash
# knit — build and launch Chau7 in one command.
# Because every sock needs knitting.
#
# Usage:
#   ./Scripts/knit           # build release + launch
#   ./Scripts/knit debug     # build debug + launch
#   ./Scripts/knit --no-run  # build only, don't launch
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

MODE="${1:-release}"
NO_RUN=0
if [[ "$MODE" == "--no-run" ]]; then
    MODE="release"
    NO_RUN=1
elif [[ "${2:-}" == "--no-run" ]]; then
    NO_RUN=1
fi

APP_NAME="Chau7"
BUILD_DIR=".build/${MODE}"
APP_DIR="${BUILD_DIR}/${APP_NAME}.app"

printf "\033[1m🧶 Knitting %s (%s)...\033[0m\n" "$APP_NAME" "$MODE"

# Build
if [[ "$MODE" == "debug" ]]; then
    swift build 2>&1 | tail -1
else
    swift build -c release 2>&1 | tail -1
fi

BIN_PATH="${BUILD_DIR}/${APP_NAME}"
if [[ ! -f "$BIN_PATH" ]]; then
    echo "Binary not found at $BIN_PATH"
    echo "Falling back to build-app.sh for full app bundle..."
    BUILD_MODE="$MODE" OPEN_AFTER_BUILD=$((1 - NO_RUN)) exec ./Scripts/build-and-run.sh
    exit 0
fi

# If build-app.sh has already created the app bundle, use that
if [[ -d "$ROOT_DIR/build/${APP_NAME}.app" ]]; then
    APP_DIR="$ROOT_DIR/build/${APP_NAME}.app"
    # Hot-swap the binary into the existing bundle
    cp "$BIN_PATH" "$APP_DIR/Contents/MacOS/$APP_NAME"
    printf "\033[32m✓ Binary hot-swapped into %s\033[0m\n" "$APP_DIR"
elif [[ -d "/Applications/${APP_NAME}.app" ]]; then
    # Hot-swap into the installed app
    cp "$BIN_PATH" "/Applications/${APP_NAME}.app/Contents/MacOS/$APP_NAME"
    APP_DIR="/Applications/${APP_NAME}.app"
    printf "\033[32m✓ Binary hot-swapped into %s\033[0m\n" "$APP_DIR"
else
    # No app bundle exists yet, do a full build
    printf "No app bundle found. Running full build-app.sh...\n"
    BUILD_MODE="$MODE" OPEN_AFTER_BUILD=$((1 - NO_RUN)) exec ./Scripts/build-and-run.sh
    exit 0
fi

if [[ "$NO_RUN" -eq 1 ]]; then
    printf "\033[1m🧶 Done. Not launching (--no-run).\033[0m\n"
    exit 0
fi

# Launch
printf "\033[1m🧶 Launching %s...\033[0m\n" "$APP_NAME"
open "$APP_DIR"
