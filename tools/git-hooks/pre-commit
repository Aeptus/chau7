#!/bin/zsh
# Pre-commit hook: ensures documentation is updated when source code changes.
# Skip with: git commit --no-verify
# Skip doc check only: CHAU7_SKIP_DOC_CHECK=1 git commit
set -e

# ── Escape hatches ──────────────────────────────────────────────────────────
if [ -n "$CHAU7_SKIP_DOC_CHECK" ]; then
    exit 0
fi

# ── Configuration ───────────────────────────────────────────────────────────
DOCS_DIR="apps/chau7-macos/docs"
CHANGELOG="$DOCS_DIR/CHANGELOG.md"
FEATURES_MD="$DOCS_DIR/FEATURES.md"
FEATURES_CSV="$DOCS_DIR/features.csv"

# ── Classify staged files ──────────────────────────────────────────────────
#
# This function decides whether a staged file is "source code that changes
# behavior." This is the policy boundary — everything downstream reacts
# to its output.
#
# Returns 0 (true)  → file is behavioral source, docs must be updated
# Returns 1 (false) → file is exempt (tests, docs, configs, assets)
#
is_behavioral_source() {
    local file="$1"

    # Blocklist approach: everything is behavioral EXCEPT known non-behavioral paths.
    # This catches new directories automatically — safe default is "requires docs."
    case "$file" in
        # Documentation & assets — exempt
        */docs/*)           return 1 ;;
        */README.md)        return 1 ;;
        *.md)               return 1 ;;
        *.csv)              return 1 ;;

        # Tests — exempt
        */Tests/*)          return 1 ;;
        */test/*)           return 1 ;;
        *_test.go)          return 1 ;;

        # Website & marketing — exempt
        website/*)          return 1 ;;

        # IDE & build artifacts — exempt
        *.xcuserstate)      return 1 ;;
        *.xcscheme)         return 1 ;;
        .gitignore)         return 1 ;;
        .editorconfig)      return 1 ;;
        *.lock)             return 1 ;;

        # Screenshots & images — exempt
        *.png|*.jpg|*.jpeg|*.gif|*.svg|*.ico) return 1 ;;

        # Git hooks themselves — exempt
        tools/git-hooks/*)  return 1 ;;

        # Everything else is behavioral
        *)                  return 0 ;;
    esac
}

# ── Gather staged files ────────────────────────────────────────────────────
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged_files" ]; then
    exit 0
fi

has_source=false
has_changelog=false
has_features_md=false
has_features_csv=false

while IFS= read -r file; do
    case "$file" in
        "$CHANGELOG")     has_changelog=true ;;
        "$FEATURES_MD")   has_features_md=true ;;
        "$FEATURES_CSV")  has_features_csv=true ;;
    esac

    if is_behavioral_source "$file"; then
        has_source=true
    fi
done <<< "$staged_files"

# ── Enforce documentation ──────────────────────────────────────────────────
if $has_source; then
    missing=()
    $has_changelog    || missing+=("$CHANGELOG")
    $has_features_md  || missing+=("$FEATURES_MD")
    $has_features_csv || missing+=("$FEATURES_CSV")

    if [ ${#missing[@]} -gt 0 ]; then
        echo ""
        echo "╭─ Documentation required ────────────────────────────────────╮"
        echo "│                                                             │"
        echo "│  This commit changes behavioral source code.                │"
        echo "│  Please update the following before committing:             │"
        echo "│                                                             │"
        for f in "${missing[@]}"; do
            printf "│    %-55s │\n" "• $f"
        done
        echo "│                                                             │"
        echo "│  Skip this check:                                           │"
        echo "│    CHAU7_SKIP_DOC_CHECK=1 git commit                        │"
        echo "│    git commit --no-verify                                   │"
        echo "│                                                             │"
        echo "╰─────────────────────────────────────────────────────────────╯"
        echo ""
        exit 1
    fi
fi

exit 0
