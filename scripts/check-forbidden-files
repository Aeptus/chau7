#!/usr/bin/env bash
# Pre-commit guard: block staging of secret/credential-looking files and oversized blobs.
# Escape hatch: CHAU7_SKIP_FORBIDDEN_CHECK=1 git commit ...

set -euo pipefail

if [[ -n "${CHAU7_SKIP_FORBIDDEN_CHECK:-}" ]]; then
  exit 0
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Size thresholds (bytes).
WARN_BYTES=$((1 * 1024 * 1024))   # 1 MB
BLOCK_BYTES=$((5 * 1024 * 1024))  # 5 MB

# Collect staged adds/modifies/renames/copies.
staged_files="$(git -C "$REPO_ROOT" diff --cached --name-only --diff-filter=ACMR || true)"
if [[ -z "$staged_files" ]]; then
  exit 0
fi

forbidden_hits=()
oversize_block_hits=()
oversize_warn_hits=()

is_forbidden_path() {
  local path="$1"
  local base="${path##*/}"

  case "$base" in
    .env|.env.*) return 0 ;;
    id_rsa*|id_ed25519*|id_ecdsa*|id_dsa*) return 0 ;;
    credentials|credentials.*) return 0 ;;
    *.pem|*.key|*.p12|*.pfx|*.keystore|*.jks) return 0 ;;
    *.mobileprovision|*.provisionprofile) return 0 ;;
    *.asc|*.gpg) return 0 ;;
    *.crt|*.cer) return 0 ;;
    authorized_keys|known_hosts) return 0 ;;
  esac

  # Secrets-looking config files (`*secret*` already covers `*secrets*`).
  case "$base" in
    *secret*.yml|*secret*.yaml|*secret*.json|*secret*.toml) return 0 ;;
  esac

  # Path-based allowlist: fixtures and docs can mention these names legitimately.
  case "$path" in
    */Tests/*) return 1 ;;
    */test/*) return 1 ;;
    */fixtures/*) return 1 ;;
    */testdata/*) return 1 ;;
    docs/*) return 1 ;;
  esac

  return 1
}

staged_size() {
  # Size of the staged blob (index version), not the working-tree file.
  local path="$1"
  git -C "$REPO_ROOT" cat-file -s ":0:$path" 2>/dev/null || printf '0'
}

while IFS= read -r file; do
  [[ -z "$file" ]] && continue

  if is_forbidden_path "$file"; then
    forbidden_hits+=("$file")
    continue
  fi

  size="$(staged_size "$file")"
  if (( size >= BLOCK_BYTES )); then
    oversize_block_hits+=("$file ($((size / 1024 / 1024)) MB)")
  elif (( size >= WARN_BYTES )); then
    oversize_warn_hits+=("$file ($((size / 1024 / 1024)) MB)")
  fi
done <<< "$staged_files"

failed=0

if (( ${#forbidden_hits[@]} > 0 )); then
  printf '\n'
  printf '╭─ Forbidden file staged ─────────────────────────────────────╮\n'
  printf '│                                                             │\n'
  printf '│  These paths look like secrets or credentials:              │\n'
  printf '│                                                             │\n'
  for path in "${forbidden_hits[@]}"; do
    printf '│    %-56s │\n' "• $path"
  done
  printf '│                                                             │\n'
  printf '│  Override (not recommended):                                │\n'
  printf '│    CHAU7_SKIP_FORBIDDEN_CHECK=1 git commit                  │\n'
  printf '│                                                             │\n'
  printf '╰─────────────────────────────────────────────────────────────╯\n'
  printf '\n'
  failed=1
fi

if (( ${#oversize_block_hits[@]} > 0 )); then
  printf '\n'
  printf '╭─ Oversized file staged (> 5 MB) ────────────────────────────╮\n'
  printf '│                                                             │\n'
  for entry in "${oversize_block_hits[@]}"; do
    printf '│    %-56s │\n' "• $entry"
  done
  printf '│                                                             │\n'
  printf '│  Large blobs bloat history. Consider:                       │\n'
  printf '│    • git-lfs for binaries you must version                  │\n'
  printf '│    • external asset storage for everything else             │\n'
  printf '│                                                             │\n'
  printf '╰─────────────────────────────────────────────────────────────╯\n'
  printf '\n'
  failed=1
fi

if (( ${#oversize_warn_hits[@]} > 0 )); then
  printf 'warning: staging files over 1 MB:\n' >&2
  for entry in "${oversize_warn_hits[@]}"; do
    printf '  • %s\n' "$entry" >&2
  done
fi

exit "$failed"
